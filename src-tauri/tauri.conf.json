{
  "$schema": "https://schema.tauri.app/config/2.0",
  "productName": "GridGuide",
  "version": "0.0.0",
  "identifier": "de.gridguide.app",
  "build": {
    "beforeDevCommand": "pnpm --dir ../frontend dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --dir ../frontend build",
    "frontendDist": "../frontend/build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GridGuide",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["deb", "appimage"]
  }
}
