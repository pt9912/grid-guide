{
  "$schema": "https://schema.tauri.app/config/2.0",
  "productName": "GridGuide",
  "version": "0.0.0",
  "identifier": "de.gridguide.app",
  "build": {
    "beforeDevCommand": "cd frontend && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd frontend && pnpm build",
    "frontendDist": "../frontend/build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GridGuide",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
